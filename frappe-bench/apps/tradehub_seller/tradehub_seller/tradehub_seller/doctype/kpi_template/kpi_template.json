   "fieldtype": "Data",
   "in_list_view": 1,
   "in_standard_filter": 1,
   "label": "Template Name",
   "reqd": 1,
   "unique": 1,
   "description": "Unique name for this KPI template (e.g., Standard Seller KPI, Premium Buyer KPI)"
  },
  {
   "fieldname": "template_code",
   "fieldtype": "Data",
   "label": "Template Code",

{
  "ci": {
    "collect": {
      "url": ["http://localhost:8080/"],
      "numberOfRuns": 3,
      "settings": {
        "onlyCategories": ["pwa"],
        "chromeFlags": "--no-sandbox --headless",
        "formFactor": "mobile",
        "screenEmulation": {
          "mobile": true,
          "width": 360,
          "height": 640,
          "deviceScaleFactor": 2
        }
      }
    },
    "assert": {
      "assertions": {
        "categories:pwa": ["error", { "minScore": 0.9 }],
        "installable-manifest": "error",
        "service-worker": "error",
        "themed-omnibox": "error",
        "splash-screen": "error",
        "viewport": "error",
        "apple-touch-icon": "error",
        "maskable-icon": "error",
        "content-width": "warn"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
